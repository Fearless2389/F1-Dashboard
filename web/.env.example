# Frontend environment template.
#
# ─── Local development ────────────────────────────────────────────────────
#   cp .env.example .env.local
#   # Leave VITE_API_URL blank — vite.config.ts proxies /api → :8000 in dev.
#   # VITE_API_PROXY only matters during `npm run dev` (vite proxy target).
#
# ─── Production build (Vercel) ────────────────────────────────────────────
#   Set in the Vercel project's Environment Variables (Production + Preview):
#     VITE_API_URL = https://<hf-user>-paddock.hf.space
#   The WebSocket URL is derived from VITE_API_URL automatically (https → wss).
#   Override with VITE_WS_URL only if the websocket sits on a different host
#   from the REST API (rare).

VITE_API_URL=
VITE_WS_URL=
VITE_API_PROXY=http://localhost:8000
