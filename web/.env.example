# Frontend environment template.
#
# ─── Local development ────────────────────────────────────────────────────
#   cp .env.example .env.local
#   # leave VITE_API_URL blank — vite.config.ts proxies /api → :8000 in dev.
#   # VITE_API_PROXY only matters during `npm run dev` (vite proxy target).
#
# ─── Production build (Vercel / Cloudflare Pages) ─────────────────────────
#   VITE_API_URL=https://paddock-api.fly.dev
#   # WebSocket URL is derived from VITE_API_URL automatically (https → wss),
#   # override with VITE_WS_URL if you front the websocket on a different host.

VITE_API_URL=
VITE_WS_URL=
VITE_API_PROXY=http://localhost:8000
