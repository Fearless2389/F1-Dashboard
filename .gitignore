# Python
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
*.egg

# Virtual environments
venv/
env/
.venv/
.env/

# Jupyter
.ipynb_checkpoints/
*.ipynb_checkpoints

# Data files (large files - never commit these)
# Note: examples/*.csv is tracked intentionally
*.parquet
*.pkl
*.pickle
*.h5
*.hdf5
# Trained model artifacts ARE tracked so they ship with the Docker image —
# the Dockerfile COPY models/ relies on these being in the git repo.
!models/trained/*.pkl
*.sqlite
*.db
data/raw/
data/processed/
data/cache/
data/live/
data_slim/

# Runtime weather caches (re-fetched on demand from Open-Meteo)
data/schedule/weather_*.json

# Models — trained artifacts are version-tracked so they ride along with
# the Docker image (Dockerfile: COPY models/). Only intermediate joblib
# scratch files stay ignored.
*.joblib
*.model

# Environment variables
.env
.env.local

# IDE
.vscode/
.idea/
*.suo
*.user

# OS
.DS_Store
Thumbs.db

# Logs
*.log
logs/

# Node / Vite (React frontend in web/)
node_modules/
web/dist/
web/.vite/
web/coverage/
web/test-results/
web/playwright-report/
web/playwright/.cache/

# Build artefacts
*.tsbuildinfo
.swc/

# Editor / OS extras
*.code-workspace
