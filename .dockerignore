*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/

# Local environment
.env
.env.*
venv/
.venv/

# Tests + docs — not needed at runtime.
tests/
docs/
notebooks/
*.ipynb
streamlit_app/

# Logs + scratch
*.log
*.tmp
scratch/
handoff.md
